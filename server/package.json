{
  "name": "qa-app-real-estate",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "start:prod": "npm run build && node src/app.js",
    "sanitize": "node build/sanitize.js",
    "build": "npm run sanitize && node build/build-public.js && node build/bundle-client.js && node build/minify-assets.js",
    "restore:dev-source": "node build/restore-dev-source.js",
    "prisma:generate": "prisma generate --no-hints",
    "db:migrate:dev": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.18.1",
    "helmet": "^7.2.0",
    "pg": "^8.16.0",
    "sanitize-html": "^2.17.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "clean-css": "^5.3.3",
    "nodemon": "^3.1.10",
    "prisma": "^6.8.2",
    "terser": "^5.39.0"
  }
}

