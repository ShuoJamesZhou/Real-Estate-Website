generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactEnquiry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  firstName String
  lastName  String
  email     String
  phone     String
  message   String

  ip        String?
  userAgent String?
}

